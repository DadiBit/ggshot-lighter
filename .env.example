### Telegram (Telethon)
# Create at https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# First run will create a session file locally (see TELEGRAM_SESSION_FILE).
# If you prefer a string session, set TELEGRAM_SESSION_STRING and leave file empty.
TELEGRAM_SESSION_FILE=ggshot.session
TELEGRAM_SESSION_STRING=

# Channel username or invite link slug (no @ needed). Example: ggshot
TELEGRAM_CHANNEL=ggshot

### Lighter
# Base URL (mainnet default shown in official docs)
LIGHTER_BASE_URL=https://mainnet.zklighter.elliot.ai

# Path to the api key json used by lighter-python SignerClient.
# You can generate it once and point the bot to it.
LIGHTER_API_KEY_CONFIG=api_key_config.json

# Account index inside Lighter (matches api_key_config.json's accountIndex)
LIGHTER_ACCOUNT_INDEX=1

# How much quote notional to deploy per signal (in USD/USDC terms).
# Used as fallback if account balance is temporarily unavailable.
TRADE_NOTIONAL_USD=10

# Per-signal allocation from currently available capital (10% = 0.10).
CAPITAL_ALLOCATION_PCT=0.10

# Entry order placement: "mid" places a single limit at the range midpoint.
ENTRY_MODE=mid

# Margin mode: CROSS or ISOLATED (CROSS recommended)
MARGIN_MODE=CROSS

# If true, bot will parse + log but not trade.
DRY_RUN=true
